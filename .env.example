# AI Kernel Dashboard Configuration
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
RATE_LIMIT_PER_MINUTE=60
KERNEL_ROOT=.

# Authentication / Production Notes
# The dashboard control endpoints (/api/start, /api/stop, /api/goal) have no
# built-in authentication. This is acceptable for local development on
# localhost. For production deployments, place an authenticating reverse proxy
# (e.g. nginx with basic auth, OAuth2 proxy, or cloud IAP) in front of the
# dashboard, or add a FastAPI dependency that checks tokens/sessions.
# AUTH_PROXY_HEADER=X-Forwarded-User
